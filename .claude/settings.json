{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/release-guard.sh\"",
            "timeout": 10,
            "statusMessage": "Vérification checklist de release"
          }
        ]
      }
    ]
  }
}
