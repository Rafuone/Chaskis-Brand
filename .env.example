# Chaskis — variables d'environnement (modèle)
#
# Copier en `.env` pour du local, ou renseigner dans la console de l'hébergeur
# (Vercel « Environment Variables », Azure App Service « Configuration »).
# TOUTES sont optionnelles : une fonctionnalité non configurée se dégrade en silence
# (repli démo / 501), le site ne casse jamais. Ne JAMAIS committer un vrai `.env`.

# ── API admin (clé partagée, Bearer) ───────────────────────────────────────
# Utilisée par publish / restore / history / perf / calendly. openssl rand -hex 24
PUBLISH_SECRET=

# ── Publication du contenu (chantier publish) ──────────────────────────────
# PAT GitHub fine-grained, permission « Contents: write » sur CE dépôt uniquement.
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
GITHUB_BRANCH=main

# ── Performance : Core Web Vitals réels (chantier perf) ─────────────────────
# Clé Google PageSpeed Insights (gratuite). Sans elle : /api/perf renvoie 501.
PAGESPEED_KEY=
# Optionnel : marge de délai de la fonction (ms). Défaut prudent pour plans à faible timeout.
# PERF_TIMEOUT_MS=9000

# ── Chatbot : LLM optionnel (chantier chatbot) ─────────────────────────────
# Fournisseur OpenAI-compatible. Sans LLM_API_KEY : mode extractif (pas de coupure).
# groq | openai | azure-openai
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
# Requis pour Azure OpenAI :
LLM_BASE_URL=
LLM_API_VERSION=

# ── Rendez-vous (chantier calendly) ────────────────────────────────────────
# Jeton API Calendly v2 (lecture des RDV, compatible plan gratuit).
CALENDLY_TOKEN=
# Correspondance email->commercial pour l'attribution, ex: a@x.ch=Sarah,b@x.ch=Marc
CALENDLY_OWNERS=
# Optionnel : budget de temps global de la synchro (ms).
# CALENDLY_BUDGET_MS=9000
# Phase 2 (disponibilité agrégée) — non activé : none | google
AVAILABILITY_PROVIDER=none
GOOGLE_CALENDAR_TOKEN=
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Sonde de fondation (chantier host) ─────────────────────────────────────
# Jeton de test lu par /api/env-check et /api/health (renvoie seulement un booléen).
PING_TOKEN=

# ── Outillage local uniquement (non requis en production) ──────────────────
# Utilisé par tools/translate.js (génération des dictionnaires i18n hors-ligne).
ANTHROPIC_API_KEY=
