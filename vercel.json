{
  "crons": [
    { "path": "/api/perf-cron", "schedule": "0 6 * * *" }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/app", "destination": "/app.html" },
    { "source": "/commander", "destination": "/commander.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/postuler", "destination": "/postuler.html" },
    { "source": "/mobilite", "destination": "/mobilite.html" },
    { "source": "/suivi/:code", "destination": "/app.html?code=:code" },
    { "source": "/admin", "destination": "/admin/editor.html" },
    { "source": "/confidentialite", "destination": "/confidentialite.html" },
    { "source": "/mentions-legales", "destination": "/mentions-legales.html" },
    { "source": "/cgv", "destination": "/cgv.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/admin",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
